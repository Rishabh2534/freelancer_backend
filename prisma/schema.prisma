// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  freelancer
  client
}

enum ProjectDuration {
  short
  medium
  long
}

enum WorkType {
  remote
  onsite
  hybrid
}

enum ApplicationStatus {
  pending
  accepted
  rejected
  withdrawn
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  projects  Project[] @relation("ProjectOwner")
  applications Application[]
  messages  Message[]
  reviews   Review[] @relation("ReviewAuthor")
  receivedReviews Review[] @relation("ReviewRecipient")
  skills    UserSkill[]

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  location  String?
  bio       String?
  website   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  deadline    DateTime
  duration    ProjectDuration
  workType    WorkType[]      @map("work_type")
  budget      String?
  status      String          @default("open")
  ownerId     String          @map("owner_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  owner        User           @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  techStack    TechStack[]
  applications Application[]

  @@map("projects")
}

model TechStack {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  name        String
  proficiency Int     @default(50)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tech_stack")
}

model Application {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  status    ApplicationStatus @default(pending)
  message   String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("applications")
}

model Channel {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  memberCount Int      @default(0) @map("member_count")
  createdAt   DateTime @default(now()) @map("created_at")

  messages Message[]

  @@map("channels")
}

model Message {
  id        String   @id @default(uuid())
  channelId String   @map("channel_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Review {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  recipientId String   @map("recipient_id")
  projectId   String?  @map("project_id")
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  author    User @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  recipient User @relation("ReviewRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model UserSkill {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  name        String
  proficiency Int     @default(50)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_skills")
}

model Roadmap {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  skill     String
  modules   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, skill])
  @@map("roadmaps")
}

